#!/bin/bash
# PXVIRT first-boot network setup
# Auto-detect first physical NIC and configure vmbr0 bridge
# Env vars: PXVIRT_IP (IP/MASK,GATEWAY e.g. 192.168.1.100/24,192.168.1.1)
set -e

# Regenerate SSH host keys (removed during build for security)
ssh-keygen -A || true
systemctl restart sshd 2>/dev/null || true
echo "SSH host keys regenerated"

IP_ADDRESS="${PXVIRT_IP:-}"
if [[ -z "$IP_ADDRESS" || ! "$IP_ADDRESS" == *,* ]]; then
    echo "ERROR: PXVIRT_IP is required, format: IP/MASK,GATEWAY"
    exit 1
fi

# Check if interface is wireless
is_wireless() {
    [[ -d "/sys/class/net/${1}/wireless" ]] ||
        [[ -e /proc/net/wireless && $(awk -v iface="${1}:" '$1 == iface {print $1}' /proc/net/wireless) ]]
}

# Check if interface is a bridge or bridge member
is_bridge_or_member() {
    ip -d link show "${1}" 2>/dev/null | grep -Eq "bridge|brport"
}

# Find first physical wired ethernet interface
NIC=""
for iface in $(ip -o link show | awk -F': ' '{print $2}' | grep -v lo); do
    # Skip virtual/bridge/wireless interfaces
    is_wireless "$iface" && continue
    is_bridge_or_member "$iface" && continue
    [[ "$iface" == vmbr* ]] && continue
    [[ "$iface" == docker* ]] && continue
    [[ "$iface" == br-* ]] && continue
    [[ "$iface" == veth* ]] && continue
    [[ "$iface" == wl* ]] && continue
    NIC="$iface"
    break
done

if [[ -z "$NIC" ]]; then
    echo "ERROR: No physical wired NIC found"
    exit 1
fi
echo "Detected NIC: $NIC"

# Parse static IP config: IP/MASK,GATEWAY
IP_CIDR="${IP_ADDRESS%%,*}"
GATEWAY="${IP_ADDRESS##*,}"
echo "Static IP: $IP_CIDR, Gateway: $GATEWAY"

# Generate /etc/network/interfaces with vmbr0 bridge
cat > /etc/network/interfaces <<IFACE
auto lo
iface lo inet loopback

iface ${NIC} inet manual

auto vmbr0
iface vmbr0 inet static
    address ${IP_CIDR}
    gateway ${GATEWAY}
    bridge-ports ${NIC}
    bridge-stp off
    bridge-fd 0
IFACE


# Restart networking (with timeout to avoid hanging)
timeout 10 ifreload -a 2>/dev/null || timeout 15 systemctl restart networking 2>/dev/null || true

# Disable this service after first run
systemctl disable pxvirt-network-setup.service
rm -f /etc/default/pxvirt-network
echo "Network setup completed: vmbr0 bridged to ${NIC}"
